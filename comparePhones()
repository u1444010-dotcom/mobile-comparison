function getWinner(d1, d2){
    let score1 = parseInt(d1.ram) + parseInt(d1.camera) + parseInt(d1.battery);
    let score2 = parseInt(d2.ram) + parseInt(d2.camera) + parseInt(d2.battery);

    return score1 > score2 ? "phone1" : "phone2";
}

function comparePhones(){

    let p1 = document.getElementById("phone1").value;
    let p2 = document.getElementById("phone2").value;

    if(!p1 || !p2){
        alert("Select both phones");
        return;
    }

    let d1 = phones[p1];
    let d2 = phones[p2];

    // 🔗 Buy links
    document.getElementById("buy1").href = d1.link;
    document.getElementById("buy2").href = d2.link;

    // 📊 Fill comparison table
    document.getElementById("ram1").innerText = d1.ram;
    document.getElementById("ram2").innerText = d2.ram;

    document.getElementById("cam1").innerText = d1.camera;
    document.getElementById("cam2").innerText = d2.camera;

    document.getElementById("bat1").innerText = d1.battery;
    document.getElementById("bat2").innerText = d2.battery;

    // 🏆 Winner logic
    let winner = getWinner(d1, d2);

    document.getElementById("phone1").style.border = "2px solid transparent";
    document.getElementById("phone2").style.border = "2px solid transparent";

    if(winner === "phone1"){
        document.getElementById("phone1").style.border = "2px solid #00ffcc";
    } else {
        document.getElementById("phone2").style.border = "2px solid #00ffcc";
    }

    document.getElementById("result").style.display = "block";
}
