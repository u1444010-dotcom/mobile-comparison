.search-box{
    position:relative;
    display:inline-block;
}

.suggestions{
    position:absolute;
    top:45px;
    left:0;
    width:100%;
    background:#11174a;
    border-radius:10px;
    display:none;
    z-index:100;
    max-height:200px;
    overflow-y:auto;
}

.suggestion-item{
    display:flex;
    align-items:center;
    gap:10px;
    padding:10px;
    cursor:pointer;
}

.suggestion-item:hover{
    background:#5b6cff;
}
