<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mobile Compare Store</title>

<style>
body{
  margin:0;
  font-family:Arial;
  background:#0f172a;
  color:white;
}

/* HEADER */
header{
  background:#131921;
  padding:15px;
  display:flex;
  align-items:center;
  justify-content:space-between;
  flex-wrap:wrap;
}

.logo{
  font-size:22px;
  font-weight:bold;
}

.search-box{
  flex:1;
  margin:10px;
}

.search-box input{
  width:100%;
  padding:10px;
  border:none;
  border-radius:6px;
}

/* CATEGORIES */
.categories{
  background:#232f3e;
  padding:10px;
  display:flex;
  justify-content:center;
  gap:15px;
  flex-wrap:wrap;
}

.categories a{
  color:white;
  text-decoration:none;
  padding:6px 10px;
  background:#37475a;
  border-radius:5px;
}

/* PRODUCTS */
.container{
  display:flex;
  justify-content:center;
  flex-wrap:wrap;
  gap:20px;
  padding:20px;
}

.card{
  background:#1f2937;
  width:220px;
  padding:15px;
  border-radius:10px;
  text-align:center;
  transition:0.3s;
}

.card:hover{
  transform:scale(1.05);
}

.card img{
  width:100%;
  border-radius:8px;
}

.card a{
  display:inline-block;
  margin-top:10px;
  background:#ff9900;
  color:black;
  padding:8px;
  text-decoration:none;
  border-radius:6px;
  font-weight:bold;
}

/* TABLE */
table{
  width:90%;
  margin:30px auto;
  border-collapse:collapse;
  background:#1f2937;
}

th,td{
  border:1px solid #374151;
  padding:12px;
  text-align:center;
}

h2{
  margin-top:30px;
}
</style>
</head>

<body>

<!-- HEADER -->
<header>
  <div class="logo">📱 MobileStore</div>

  <div class="search-box">
    <input type="text" id="search" placeholder="Search mobiles...">
  </div>
</header>

<!-- CATEGORIES -->
<div class="categories">
  <a href="#">🍎 Apple</a>
  <a href="#">📱 Samsung</a>
  <a href="#">📷 Xiaomi</a>
  <a href="#">🔥 Best Deals</a>
</div>

<!-- PRODUCTS -->
<h2>🔥 Featured Mobiles</h2>

<div class="container">

  <div class="card" data-name="iphone 15">
    <img src="https://fdn2.gsmarena.com/vv/pics/apple/apple-iphone-15-1.jpg">
    <h3>iPhone 15</h3>
    <p>$999</p>
    <a href="https://www.amazon.com/Apple-iPhone-15-128GB-Black/dp/B0CMPMY9ZZ?tag=mobilecompa09-20" target="_blank">Buy on Amazon</a>
  </div>

  <div class="card" data-name="samsung s24">
    <img src="https://fdn2.gsmarena.com/vv/pics/samsung/samsung-galaxy-s24-1.jpg">
    <h3>Samsung S24</h3>
    <p>$899</p>
    <a href="https://www.amazon.com/SAMSUNG-Galaxy-S24-Ultra-Titanium/dp/B0D362HGNP?tag=mobilecompa09-20" target="_blank">Buy on Amazon</a>
  </div>

</div>

<!-- 📊 5 MOBILE COMPARISON (FIXED + INSIDE BODY) -->
<h2>📊 5 Mobile Comparison Table</h2>

<table>

<tr>
  <th>Feature</th>
  <th>iPhone Hot 10</th>
  <th>iPhone 11</th>
  <th>Samsung A07</th>
  <th>Mobile 4</th>
  <th>Mobile 5</th>
</tr>

<tr>
  <td>Price</td>
  <td>$499</td>
  <td>$599</td>
  <td>$199</td>
  <td>---</td>
  <td>---</td>
</tr>

<tr>
  <td>Camera</td>
  <td>12MP</td>
  <td>12MP Dual</td>
  <td>13MP</td>
  <td>---</td>
  <td>---</td>
</tr>

<tr>
  <td>Battery</td>
  <td>3000 mAh</td>
  <td>3110 mAh</td>
  <td>5000 mAh</td>
  <td>---</td>
  <td>---</td>
</tr>

<tr>
  <td>Gaming</td>
  <td>Medium</td>
  <td>High</td>
  <td>Basic</td>
  <td>---</td>
  <td>---</td>
</tr>

<tr>
  <td>Buy</td>
  <td><a href="#">Amazon</a></td>
  <td><a href="https://www.amazon.com/Apple-iPhone-11/dp/B07ZPKN6YR?tag=mobilecompa09-20">Amazon</a></td>
  <td><a href="#">Amazon</a></td>
  <td>---</td>
  <td>---</td>
</tr>

</table>

<!-- SEARCH SCRIPT -->
<script>
document.getElementById("search").addEventListener("keyup", function(){
  let value = this.value.toLowerCase();
  let cards = document.querySelectorAll(".card");

  cards.forEach(card=>{
    let name = card.getAttribute("data-name");
    card.style.display = name.includes(value) ? "block" : "none";
  });
});
</script>

</body>
</html>
