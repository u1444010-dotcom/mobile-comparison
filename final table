.compare-table {
  width: 90%;
  margin: 30px auto;
  border-collapse: collapse;
  background: #1f2937;
  color: white;
  text-align: center;
  border-radius: 10px;
  overflow: hidden;
}

.compare-table th {
  background: #111827;
  padding: 15px;
}

.compare-table td {
  padding: 12px;
  border-bottom: 1px solid #374151;
}

.compare-table img {
  border-radius: 8px;
}

.compare-table a {
  background: #22c55e;
  padding: 8px 12px;
  color: white;
  text-decoration: none;
  border-radius: 6px;
}
