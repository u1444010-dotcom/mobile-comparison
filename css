body {
  font-family: Arial;
  background: #0f172a;
  color: white;
  text-align: center;
  margin: 0;
}

header {
  padding: 20px;
  background: #111827;
}

.compare-table {
  width: 90%;
  margin: 30px auto;
  border-collapse: collapse;
  background: #1f2937;
  border-radius: 10px;
  overflow: hidden;
}

.compare-table th {
  background: #111827;
  padding: 15px;
}

.compare-table td {
  padding: 12px;
  border-bottom: 1px solid #374151;
}

.compare-table img {
  width: 120px;
  border-radius: 8px;
}

a {
  background: #22c55e;
  padding: 8px 12px;
  color: white;
  text-decoration: none;
  border-radius: 6px; 
